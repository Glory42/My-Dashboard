# PostgreSQL connection string
# Neon example:  postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
# Local example: postgresql://postgres:password@localhost:5432/dashboard_todo
DATABASE_URL="postgresql://user:password@localhost:5432/dashboard_todo"

# Secret used to sign JWT tokens — use a long random string in production
JWT_SECRET="change-me-to-a-long-random-secret"

# JWT token expiry (e.g. 7d, 24h, 3600s)
JWT_EXPIRES_IN="7d"

# Allowed CORS origin — frontend URL
# Local:      http://localhost:5173
# Production: https://dash.gorkemkaryol.dev
FRONTEND_URL="http://localhost:5173"

# development | production
NODE_ENV="development"

# Port the API listens on
PORT=3000
